# VidSnap 环境变量配置
# 复制此文件为 .env.local 并填入实际值

# DeepSeek API 密钥（必填）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxx

# 硅基流动 SenseVoice API 密钥（可选，有则优先云端转写）
# 获取地址：https://siliconflow.cn/
SENSEVOICE_API_KEY=sk-xxx

# LLM 提供商（默认 deepseek，可选 claude）
LLM_PROVIDER=deepseek

# Whisper 模型（可选，默认 large-v3，仅本地生效）
WHISPER_MODEL=large-v3